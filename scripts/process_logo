#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

LOGO_DIR="$REPO_ROOT/assets/logo"

STRIPPED="$(mktemp --suffix=.svg)"
trap 'rm -f "$STRIPPED"' EXIT

command -v svgo >/dev/null 2>&1 || npm install -g svgo

# Strip hidden Inkscape layers, then export an optimized SVG and PNGs at
# the requested sizes. PNGs are rendered from the stripped pre-svgo SVG
# so svgo's path simplifications don't influence the bitmap output.
process_source() {
    local stem="$1"; shift
    local sizes=("$@")
    local src="$LOGO_DIR/$stem.svg"
    local opt="$LOGO_DIR/$stem.opt.svg"

    python3 "$SCRIPT_DIR/_strip_hidden_layers.py" "$src" "$STRIPPED"
    inkscape --export-plain-svg --export-filename="$opt" "$STRIPPED"
    svgo "$opt" -o "$opt"

    for size in "${sizes[@]}"; do
        inkscape \
            --export-type=png \
            --export-width="$size" \
            --export-filename="$LOGO_DIR/$stem-$size.png" \
            "$STRIPPED"
    done
}

# no-bg (transparent): README image + favicon + manifest "any" purpose.
process_source "inkscape-logo.no-bg" 192 512

# bg (opaque grey gradient): manifest "maskable" purpose (Android) +
# iOS apple-touch-icon (180).
process_source "inkscape-logo.bg" 180 192 512